# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Note: The following are stored in Supabase config table, not as env vars:
# - password_hash (SHA-256 hash of portal password)
# - github_pat (Fine-grained GitHub Personal Access Token)
# - github_repo (owner/repo format, e.g., username/juliz-portal)
